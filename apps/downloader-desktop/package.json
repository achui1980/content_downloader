{
  "name": "downloader-desktop",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist-electron/main/app.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "vite",
    "dev:electron": "node scripts/dev-electron.mjs",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run build:renderer && npm run build:electron",
    "prepare:downloader": "npm install --prefix ../../tools/download-comic-2025copy && PLAYWRIGHT_BROWSERS_PATH=0 npm exec --prefix ../../tools/download-comic-2025copy playwright install chromium && npm run build --prefix ../../tools/download-comic-2025copy",
    "package": "npm run prepare:downloader && electron-builder --config electron-builder.yml"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.8",
    "vitest": "^2.1.1"
  }
}
